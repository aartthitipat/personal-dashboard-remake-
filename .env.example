# Required for Rude to read uploaded slips (Anthropic vision API), and for
# the Study team (hee, kuy, tad)
ANTHROPIC_API_KEY=

# Optional: override the model Rude uses to extract slip data
# RUDE_MODEL=claude-haiku-4-5-20251001

# Optional: override the models the Study team members use
# RESEARCHER_MODEL=claude-sonnet-5
# DEBATER_MODEL=claude-opus-4-8
# TEACHER_MODEL=claude-sonnet-5

# Supabase Postgres connection string - use the "Transaction pooler" URI from
# Project Settings -> Database -> Connect, not the direct connection.
DATABASE_URL=

# Supabase project URL and anon/publishable key, from Project Settings -> API.
SUPABASE_URL=
SUPABASE_ANON_KEY=
